  const G5_POS = [
    [7,  17, 20],
    [27, 12, 21],
    [58, 10, 23],
    [33, 42, 21],
    [6,  55, 21],
    [34, 66, 21],
    [58, 40, 25],
    [60, 64, 19],
  ];

  let g5Queue=[], g5Current=null, g5Lives=3, g5Correct=0, g5Round=0, g5Answered=false, g5DotStates=[];

  function startGame5() {
    showScreen('game5-screen');
    // Show start screen, hide game elements
    document.getElementById('g5-startScreen').classList.remove('hidden');
    document.getElementById('g5-endScreen').classList.add('hidden');
    document.getElementById('g5-topbar').style.display = 'none';
    document.getElementById('g5-promptCard').style.display = 'none';
    document.getElementById('g5-hud').style.display = 'none';
    document.getElementById('g5-dotsRow').style.display = 'none';
    document.getElementById('g5-bowlWrap').style.display = 'none';
  }

  function g5StartGame() {
    g5Lives=3; g5Correct=0; g5Round=0; g5Answered=false;
    g5DotStates = new Array(G5_ANIMALS.length).fill('pending');
    g5Queue = [...G5_ANIMALS].sort(() => Math.random() - 0.5);
    // Hide overlays, show game elements
    document.getElementById('g5-startScreen').classList.add('hidden');
    document.getElementById('g5-endScreen').classList.add('hidden');
    document.getElementById('g5-flash').classList.remove('show');
    document.getElementById('g5-topbar').style.display = 'flex';
    document.getElementById('g5-promptCard').style.display = 'block';
    document.getElementById('g5-hud').style.display = 'flex';
    document.getElementById('g5-dotsRow').style.display = 'flex';
    document.getElementById('g5-bowlWrap').style.display = 'flex';
    g5BuildBowl();
    g5RenderDots();
    g5NextRound();
  }

  function g5BuildBowl() {
    const c = document.getElementById('g5-animalsContainer');
    c.innerHTML = '';
    G5_ANIMALS.forEach((a, i) => {
      const [l, t, w] = G5_POS[i];
      const btn = document.createElement('button');
      btn.className = 'animal-spot';
      btn.id = 'g5btn-' + a.id;
      btn.style.cssText = `left:${l}%;top:${t}%;width:${w}%;`;
      btn.innerHTML = a.svg + `<div class="animal-label">${a.name}</div>`;
      btn.addEventListener('click', () => g5HandleClick(a.id, btn));
      c.appendChild(btn);
    });
  }

  function g5NextRound() {
    if (g5Round >= G5_ANIMALS.length || g5Lives <= 0) { g5EndGame(); return; }
    g5Answered = false;
    g5Current = g5Queue[g5Round];
    document.getElementById('g5-promptName').textContent = g5Current.name;
    const card = document.getElementById('g5-promptCard');
    card.classList.remove('pop'); void card.offsetWidth; card.classList.add('pop');
    document.getElementById('g5-hudLives').textContent = '❤️'.repeat(g5Lives) + '🤍'.repeat(Math.max(0, 3 - g5Lives));
    document.getElementById('g5-hudScore').textContent = `⭐ ${g5Correct} / 8`;
    g5RenderDots();
    setTimeout(g5Speak, 300);
  }

  function g5Speak() {
    if (!g5Current) return;
    speakText(g5Current.name);
  }

  function g5HandleClick(id, btn) {
    if (g5Answered) return;
    g5Answered = true;
    if (id === g5Current.id) {
      btn.classList.add('correct');
      g5Correct++; g5DotStates[g5Round] = 'done';
      g5ShowFlash(true);
      setTimeout(() => { btn.classList.remove('correct'); g5Round++; g5NextRound(); }, 950);
    } else {
      btn.classList.add('wrong');
      g5Lives--; g5DotStates[g5Round] = 'fail';
      g5ShowFlash(false);
      if (g5Lives <= 0) { setTimeout(g5EndGame, 950); return; }
      setTimeout(() => { btn.classList.remove('wrong'); g5Answered = false; g5Round++; g5NextRound(); }, 900);
    }
  }

  function g5ShowFlash(ok) {
    const okM=[['🎉','¡Correcto!'],['⭐','¡Muy bien!'],['🥳','¡Genial!'],['🌟','¡Excelente!']];
    const noM=[['❌','¡Ups!'],['😅','¡Inténtalo!'],['🌊','¡No era ese!']];
    const pool = ok ? okM : noM;
    const p = pool[Math.floor(Math.random() * pool.length)];
    document.getElementById('g5-flEmoji').textContent = p[0];
    document.getElementById('g5-flMsg').textContent = p[1];
    const el = document.getElementById('g5-flash');
    el.style.background = ok
      ? 'radial-gradient(circle,rgba(30,200,90,.3),transparent 70%)'
      : 'radial-gradient(circle,rgba(220,50,50,.3),transparent 70%)';
    el.classList.add('show');
    setTimeout(() => el.classList.remove('show'), 700);
  }

  function g5RenderDots() {
    const row = document.getElementById('g5-dotsRow'); row.innerHTML = '';
    g5DotStates.forEach((s, i) => {
      const d = document.createElement('div');
      d.className = 'dot' + (s==='done'?' done':s==='fail'?' fail':i===g5Round?' active':'');
      row.appendChild(d);
    });
  }

  function g5EndGame() {
    const pct = g5Correct / G5_ANIMALS.length;
    let emoji, title, stars;
    if (pct === 1)      { emoji='🏆'; title='¡Increíble!';  stars='⭐⭐⭐'; }
    else if (pct >= .75){ emoji='🎉'; title='¡Excelente!';  stars='⭐⭐⭐'; }
    else if (pct >= .5) { emoji='😊'; title='¡Muy bien!';   stars='⭐⭐'; }
    else                { emoji='💪'; title='¡Sigue así!';  stars='⭐'; }
    document.getElementById('g5-endEmoji').textContent = emoji;
    document.getElementById('g5-endTitle').textContent = title;
    document.getElementById('g5-endStars').textContent = stars;
    document.getElementById('g5-endScore').textContent = `Acertaste ${g5Correct} de ${G5_ANIMALS.length} animales`;
    document.getElementById('g5-bowlWrap').style.display = 'none';
    document.getElementById('g5-topbar').style.display = 'none';
    document.getElementById('g5-promptCard').style.display = 'none';
    document.getElementById('g5-hud').style.display = 'none';
    document.getElementById('g5-dotsRow').style.display = 'none';
    document.getElementById('g5-endScreen').classList.remove('hidden');
  }

  // =================== INIT ===================
  showScreen('screen-home');

  // =================== PWA: SERVICE WORKER ===================
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', () => {
      navigator.serviceWorker.register('./sw.js')
        .then(reg => console.log('SW registrado:', reg.scope))
        .catch(err => console.log('SW error:', err));
    });
  }

  // =================== PWA: INSTALL BANNER ===================
  let deferredPrompt = null;
  const installBanner = document.getElementById('install-banner');
  const installBtn = document.getElementById('install-btn');
  const installClose = document.getElementById('install-close');

  window.addEventListener('beforeinstallprompt', e => {
    e.preventDefault();
    deferredPrompt = e;
    if (installBanner) installBanner.style.display = 'flex';
  });

  if (installBtn) {
    installBtn.addEventListener('click', async () => {
      if (!deferredPrompt) return;
      deferredPrompt.prompt();
      const { outcome } = await deferredPrompt.userChoice;
      deferredPrompt = null;
      if (installBanner) installBanner.style.display = 'none';
    });
  }

  if (installClose) {
    installClose.addEventListener('click', () => {
      if (installBanner) installBanner.style.display = 'none';
    });
  }

  window.addEventListener('appinstalled', () => {
    if (installBanner) installBanner.style.display = 'none';
    deferredPrompt = null;
  });
</script>
