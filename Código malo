  function startGame4() {
    g4LevelIdx = 0;
    g4RoundIdx = 0;
    g4Picking = false;
    currentGame = 'game4';
    g4RenderRound();
    showScreen('game4-screen');
  }

  function g4RenderRound() {
    g4Picking = false;
    const levelKey = g4LevelOrder[g4LevelIdx];
    const level = g4Data[levelKey];
    const round = level.rounds[g4RoundIdx];

    document.getElementById('g4-level-badge').textContent =
      level.name + ' · ' + (g4RoundIdx + 1) + '/' + level.rounds.length;
    document.getElementById('g4-dot').style.background = level.color;
    document.getElementById('g4-feedback').textContent = '';

    // Build 6 items: 1 correct + 5 wrong, shuffled
    const items = [
      { ...round.correct, isCorrect: true },
      ...round.wrong.map(w => ({ ...w, isCorrect: false }))
    ].sort(() => Math.random() - 0.5);

    const container = document.getElementById('g4-objects');
    container.innerHTML = '';

    items.forEach(item => {
      const div = document.createElement('div');
      div.className = 'g4-obj';
      div.innerHTML = item.svg;
      div.setAttribute('title', item.label);
      div.onclick = () => g4Pick(div, item, level);
      container.appendChild(div);
    });

    speakText('Toca el objeto de color ' + level.colorName);
  }

  function g4Pick(el, item, level) {
    if (g4Picking) return;

    if (item.isCorrect) {
      g4Picking = true;
      el.classList.add('correct');
      speakText('¡Muy bien!');
      document.getElementById('g4-feedback').textContent = '✅ ¡Muy bien!';

      setTimeout(() => {
        const levelKey = g4LevelOrder[g4LevelIdx];
        const levelData = g4Data[levelKey];
        // Next round or next level or finish
        if (g4RoundIdx < levelData.rounds.length - 1) {
          g4RoundIdx++;
          g4RenderRound();
        } else if (g4LevelIdx < g4LevelOrder.length - 1) {
          g4LevelIdx++;
          g4RoundIdx = 0;
          g4RenderRound();
        } else {
          showSuccess();
        }
      }, 900);

    } else {
      el.classList.add('wrong');
      speakText('Ese no es de color ' + level.colorName);
      document.getElementById('g4-feedback').textContent = '❌ Ese no es, inténtalo';
      setTimeout(() => {
        el.classList.remove('wrong');
        document.getElementById('g4-feedback').textContent = '';
      }, 900);
    }
  }

