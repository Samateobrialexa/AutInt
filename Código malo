    <div style="font-weight:800;font-size:1rem;color:#333;">Instalar AutInt Juegos</div>
    <div style="font-size:0.82rem;color:#888;margin-top:2px;">Juega sin internet, desde tu pantalla</div>
  </div>
  <button id="install-btn" style="background:#4a90d9;color:#fff;border:none;border-radius:10px;
    padding:10px 18px;font-weight:800;font-size:0.9rem;font-family:'Nunito',sans-serif;cursor:pointer;
    white-space:nowrap;">Instalar</button>
  <button id="install-close" style="background:none;border:none;cursor:pointer;font-size:1.3rem;
