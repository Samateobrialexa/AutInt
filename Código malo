<script>
  // =================== NAVIGATION ===================
  function showScreen(id) {
    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    const el = document.getElementById(id);
    if (el) { el.classList.add('active'); el.classList.add('fade-in'); }
  }

  // =================== TTS (mobile-compatible) ===================
  let ttsReady = false;

  // Unlock speech on first user interaction (required by mobile browsers)
  function unlockTTS() {
    if (ttsReady) return;
    ttsReady = true;
    // Warm up with a silent utterance to unlock iOS/Android
    const warmup = new SpeechSynthesisUtterance('');
    warmup.volume = 0;
    speechSynthesis.speak(warmup);
  }
  document.addEventListener('touchstart', unlockTTS, { once: true });
  document.addEventListener('mousedown', unlockTTS, { once: true });

  function speakText(text) {
    if (!('speechSynthesis' in window)) return;
    speechSynthesis.cancel();

    function doSpeak() {
      const u = new SpeechSynthesisUtterance(text);
      // Try Spanish voice, fall back to any available
      const voices = speechSynthesis.getVoices();
      const esVoice = voices.find(v => v.lang.startsWith('es')) || voices[0];
      if (esVoice) u.voice = esVoice;
      u.lang = 'es-ES';
      u.rate = 0.85;
      u.pitch = 1.1;
      u.volume = 1;
      speechSynthesis.speak(u);
    }

    // Voices may not be loaded yet on mobile
    if (speechSynthesis.getVoices().length > 0) {
      doSpeak();
    } else {
      speechSynthesis.addEventListener('voiceschanged', doSpeak, { once: true });
    }
  }

  // =================== SUCCESS ===================
  let currentGame = null;
  function showSuccess() {
    document.getElementById('successOverlay').classList.add('show');
  }
  function closeSuccess() {
    document.getElementById('successOverlay').classList.remove('show');
    if (currentGame === 'game1') { startGame1(); }
    else if (currentGame === 'game2') { startGame2(); }
    else if (currentGame === 'game3') { startGame3(); }
    else if (currentGame === 'game4') { startGame4(); }
  }

  // =================== UNIVERSAL DRAG ENGINE (mouse + touch) ===================
  let activeDrag = null;      // { el, ghost, offsetX, offsetY, game }
  let lastHighlight = null;

  function initDraggable(el) {
    if (el._dragInited) return;   // prevent duplicate listeners
    el._dragInited = true;
    el.addEventListener('mousedown', dragDown);
    el.addEventListener('touchstart', dragDown, { passive: false });
  }

  function dragDown(e) {
    const srcEl = e.currentTarget;
    if (srcEl.style.pointerEvents === 'none' || srcEl.style.opacity === '0.3') return;
    e.preventDefault();

    // Speak the element name when picked up
    const label = srcEl.querySelector('.g1-drag-label');
    if (label) speakText(label.textContent);

    const touch = e.touches ? e.touches[0] : e;
    const rect = srcEl.getBoundingClientRect();
    const offsetX = touch.clientX - rect.left;
    const offsetY = touch.clientY - rect.top;

    // Create floating ghost
    const ghost = srcEl.cloneNode(true);
    ghost.style.cssText = `
      position: fixed; z-index: 9999; pointer-events: none;
      width: ${rect.width}px; height: ${rect.height}px;
      left: ${rect.left}px; top: ${rect.top}px;
      opacity: 0.85; transform: scale(1.12);
      transition: transform 0.1s; border-radius: 12px;
    `;
    document.body.appendChild(ghost);
    srcEl.style.opacity = '0.35';

    activeDrag = { el: srcEl, ghost, offsetX, offsetY };

    document.addEventListener('mousemove', dragMove);
    document.addEventListener('mouseup', dragUp);
    document.addEventListener('touchmove', dragMove, { passive: false });
    document.addEventListener('touchend', dragUp);
  }

  function dragMove(e) {
    if (!activeDrag) return;
    e.preventDefault();
    const touch = e.touches ? e.touches[0] : e;
    const x = touch.clientX - activeDrag.offsetX;
    const y = touch.clientY - activeDrag.offsetY;
    activeDrag.ghost.style.left = x + 'px';
    activeDrag.ghost.style.top  = y + 'px';

    // Highlight drop zones under finger/cursor
    activeDrag.ghost.style.display = 'none';
    const elBelow = document.elementFromPoint(touch.clientX, touch.clientY);
    activeDrag.ghost.style.display = '';
    const zone = elBelow ? elBelow.closest('[data-drop-zone]') : null;
    if (lastHighlight && lastHighlight !== zone) lastHighlight.classList.remove('dz-hover');
    if (zone && !zone.classList.contains('matched')) {
      zone.classList.add('dz-hover');
      lastHighlight = zone;
    } else {
      lastHighlight = null;
    }
  }

  function dragUp(e) {
    if (!activeDrag) return;
    document.removeEventListener('mousemove', dragMove);
    document.removeEventListener('mouseup', dragUp);
    document.removeEventListener('touchmove', dragMove);
    document.removeEventListener('touchend', dragUp);

    const touch = e.changedTouches ? e.changedTouches[0] : e;
    activeDrag.ghost.style.display = 'none';
    const elBelow = document.elementFromPoint(touch.clientX, touch.clientY);
    activeDrag.ghost.style.display = '';

    if (lastHighlight) { lastHighlight.classList.remove('dz-hover'); lastHighlight = null; }

    const zone = elBelow ? elBelow.closest('[data-drop-zone]') : null;

    if (zone && !zone.classList.contains('matched')) {
      const game = zone.getAttribute('data-drop-zone');
      if (game === 'g1') handleG1Drop(activeDrag.el, zone);
      if (game === 'g2') handleG2Drop(activeDrag.el, zone);
    } else {
      // Snap back
      activeDrag.el.style.opacity = '1';
    }

    activeDrag.ghost.remove();
    activeDrag = null;
  }

  // =================== GAME 1: COLORS ===================
  let g1Matched = 0;

  function startGame1() {
    g1Matched = 0;
    currentGame = 'game1';
    // Reset drop zones
    ['target-rojo','target-amarillo','target-verde'].forEach(id => {
      const el = document.getElementById(id);
      el.classList.remove('matched');
      // Remove any cloned card inside
      el.querySelectorAll('.g1-drag-card').forEach(c => c.remove());
      // Restore label visibility
      const lbl = el.querySelector('.g1-drop-label');
      if (lbl) lbl.style.opacity = '1';
    });
    // Reset draggable cards
    ['drag-sol','drag-arbol','drag-gorro'].forEach(id => {
      const el = document.getElementById(id);
      if (el) {
        el.style.opacity = '1';
        el.style.pointerEvents = 'auto';
        el._dragInited = false;   // allow re-binding after reset
      }
    });
    document.getElementById('g1-feedback').textContent = '';
    showScreen('game1');
    // Bind draggables after screen shown
    requestAnimationFrame(() => {
      ['drag-sol','drag-arbol','drag-gorro'].forEach(id => {
        const el = document.getElementById(id);
        if (el) initDraggable(el);
      });
    });
  }

  function handleG1Drop(dragEl, target) {
    const expected = dragEl.getAttribute('data-target');
    if (target.id === expected) {
      target.classList.add('matched');
      // Place a clone of the card inside the drop zone
      const clone = dragEl.cloneNode(true);
      clone.style.pointerEvents = 'none';
      clone.style.cursor = 'default';
      clone._dragInited = true;
      target.appendChild(clone);
      // Hide the label text
      const lbl = target.querySelector('.g1-drop-label');
      if (lbl) lbl.style.opacity = '0';
      dragEl.style.opacity = '0.25';
      dragEl.style.pointerEvents = 'none';
      speakText('¡Correcto!');
      document.getElementById('g1-feedback').textContent = '✅ ¡Correcto!';
      document.getElementById('g1-feedback').style.color = '#27ae60';
      g1Matched++;
      if (g1Matched === 3) setTimeout(showSuccess, 600);
    } else {
      dragEl.style.opacity = '1';
      speakText('Inténtalo de nuevo');
      document.getElementById('g1-feedback').textContent = '❌ Inténtalo de nuevo';
      document.getElementById('g1-feedback').style.color = '#e74c3c';
      target.style.animation = 'shake 0.4s';
      setTimeout(() => target.style.animation = '', 500);
    }
  }

  // =================== GAME 2: FRUITS ===================
  let g2Matched = 0;

  function startGame2() {
    g2Matched = 0;
    currentGame = 'game2';
    ['shadow-zanahoria','shadow-pera','shadow-manzana'].forEach(id => {
      const el = document.getElementById(id);
      el.classList.remove('matched');
    });
    ['drag-manzana','drag-zanahoria','drag-pera'].forEach(id => {
      const el = document.getElementById(id);
      if (el) { el.style.opacity = '1'; el.style.pointerEvents = 'auto'; el._dragInited = false; }
    });
    document.getElementById('g2-feedback').textContent = '';
    showScreen('game2-screen');
    requestAnimationFrame(() => {
      ['drag-manzana','drag-zanahoria','drag-pera'].forEach(id => {
        const el = document.getElementById(id);
        if (el) initDraggable(el);
      });
    });
  }

  function handleG2Drop(dragEl, target) {
    const type   = dragEl.getAttribute('data-type');
    const accept = target.getAttribute('data-accept');
    if (type === accept) {
      target.classList.add('matched');
      target.innerHTML = dragEl.innerHTML;
      dragEl.style.opacity = '0.3';
      dragEl.style.pointerEvents = 'none';
      speakText('¡Muy bien!');
      document.getElementById('g2-feedback').textContent = '✅ ¡Muy bien!';
      g2Matched++;
      if (g2Matched === 3) setTimeout(showSuccess, 600);
    } else {
      dragEl.style.opacity = '1';
      speakText('Ese no es, inténtalo de nuevo');
      document.getElementById('g2-feedback').textContent = '❌ Inténtalo de nuevo';
      target.style.animation = 'shake 0.4s';
      setTimeout(() => target.style.animation = '', 500);
    }
  }

  // =================== GAME 3: ANIMALS ===================
  const g3Animals = [
    { emoji: '🐱', name: 'Gato', type: 'gato' },
    { emoji: '🐶', name: 'Perro', type: 'perro' },
  ];

  // =================== ANIMAL SOUNDS (Web Audio API) ===================
  let audioCtx = null;
  function getAudioCtx() {
    if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    if (audioCtx.state === 'suspended') audioCtx.resume();
    return audioCtx;
  }

  function playDogBark() {
    const ctx = getAudioCtx();
    const now = ctx.currentTime;

    function bark(startTime) {
      // Noise source for rough texture
      const bufferSize = ctx.sampleRate * 0.18;
      const buffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
      const data = buffer.getChannelData(0);
      for (let i = 0; i < bufferSize; i++) data[i] = (Math.random() * 2 - 1);

      const noise = ctx.createBufferSource();
      noise.buffer = buffer;

      // Band-pass to shape like a bark
      const bp = ctx.createBiquadFilter();
      bp.type = 'bandpass';
      bp.frequency.setValueAtTime(520, startTime);
      bp.frequency.exponentialRampToValueAtTime(280, startTime + 0.12);
      bp.Q.value = 1.2;

      const gain = ctx.createGain();
      gain.gain.setValueAtTime(0, startTime);
      gain.gain.linearRampToValueAtTime(1.2, startTime + 0.02);
      gain.gain.exponentialRampToValueAtTime(0.001, startTime + 0.18);

      noise.connect(bp);
      bp.connect(gain);
      gain.connect(ctx.destination);
      noise.start(startTime);
      noise.stop(startTime + 0.2);

      // Tonal component (osc for pitch)
      const osc = ctx.createOscillator();
      osc.type = 'sawtooth';
      osc.frequency.setValueAtTime(340, startTime);
      osc.frequency.exponentialRampToValueAtTime(200, startTime + 0.14);
      const oscGain = ctx.createGain();
      oscGain.gain.setValueAtTime(0, startTime);
      oscGain.gain.linearRampToValueAtTime(0.5, startTime + 0.02);
      oscGain.gain.exponentialRampToValueAtTime(0.001, startTime + 0.16);
      osc.connect(oscGain);
      oscGain.connect(ctx.destination);
      osc.start(startTime);
      osc.stop(startTime + 0.18);
    }

    bark(now);
    bark(now + 0.28);  // two barks: "guau guau"
  }

  function playCatMeow() {
    const ctx = getAudioCtx();
    const now = ctx.currentTime;

    const osc = ctx.createOscillator();
    osc.type = 'sine';

    // Meow pitch contour: rises then falls
    osc.frequency.setValueAtTime(380, now);
    osc.frequency.linearRampToValueAtTime(900, now + 0.15);
    osc.frequency.linearRampToValueAtTime(600, now + 0.35);
    osc.frequency.exponentialRampToValueAtTime(320, now + 0.55);

    // Add vibrato
    const vibLfo = ctx.createOscillator();
    vibLfo.frequency.value = 6;
    const vibGain = ctx.createGain();
    vibGain.gain.value = 18;
    vibLfo.connect(vibGain);
    vibGain.connect(osc.frequency);

    // Formant filter (nasal meow character)
    const filter = ctx.createBiquadFilter();
    filter.type = 'bandpass';
    filter.frequency.setValueAtTime(900, now);
    filter.frequency.linearRampToValueAtTime(1200, now + 0.2);
    filter.frequency.linearRampToValueAtTime(700, now + 0.55);
    filter.Q.value = 3;

    const gain = ctx.createGain();
    gain.gain.setValueAtTime(0, now);
    gain.gain.linearRampToValueAtTime(0.8, now + 0.08);
    gain.gain.setValueAtTime(0.8, now + 0.4);
    gain.gain.exponentialRampToValueAtTime(0.001, now + 0.6);

    osc.connect(filter);
    filter.connect(gain);
    gain.connect(ctx.destination);

    vibLfo.start(now);
    osc.start(now);
    osc.stop(now + 0.65);
    vibLfo.stop(now + 0.65);
  }

  function playAnimalSound(type) {
    if (type === 'gato') speakText('MIAAUUUU');
    else if (type === 'perro') speakText('WUAFFF WUAFFF');
  }

  const g3Questions = [
    { ask: 'GATO', answer: 'gato' },
    { ask: 'PERRO', answer: 'perro' },
    { ask: 'GATO', answer: 'gato' },
    { ask: 'PERRO', answer: 'perro' },
    { ask: 'GATO', answer: 'gato' },
    { ask: 'PERRO', answer: 'perro' },
  ];

  let g3Current = 0;
  let g3Score = 0;
  let g3Answered = false;

  function startGame3() {
    g3Current = 0; g3Score = 0; g3Answered = false;
    currentGame = 'game3';
    document.getElementById('g3-next').style.display = 'none';
    document.getElementById('g3-feedback').textContent = '';
    g3Render();
    showScreen('game3-screen');
  }

  function g3Render() {
    const q = g3Questions[g3Current];
    document.getElementById('g3-question').textContent = '¿Cuál es el ' + q.ask + '?';
    document.getElementById('g3-score').textContent = 'Puntos: ' + g3Score + ' / 6';
    document.getElementById('g3-progress').style.width = (g3Current / g3Questions.length * 100) + '%';
    document.getElementById('g3-feedback').textContent = '';
    document.getElementById('g3-next').style.display = 'none';
    g3Answered = false;

    // Shuffle display order
    const shuffled = [...g3Animals].sort(() => Math.random() - 0.5);
    const container = document.getElementById('g3-animals');
    container.innerHTML = '';

    shuffled.forEach(animal => {
      const div = document.createElement('div');
      div.className = 'g3-animal';
      div.innerHTML = `
        <div class="g3-animal-box" id="abox-${animal.type}">${animal.emoji}</div>
        <span class="g3-animal-name">${animal.name}</span>
